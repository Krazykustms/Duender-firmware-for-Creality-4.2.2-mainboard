{
  "Configuration.h": [
    {
      "op": "Enable",
      "searchfor": "COREXY",
      "comment": "Duender MGN9H CoreXY kinematics"
    },
    {
      "op": "CustomVal",
      "searchfor": "CONFIGURATION_H_VERSION",
      "value": "02010300",
      "comment": "Match New-Year-2025 Marlin (legacy T13 tag used 02010200)"
    },
    {
      "op": "Custom",
      "mask": "{.*}",
      "searchfor": "DEFAULT_AXIS_STEPS_PER_UNIT",
      "value": "{ 80, 80, 400, 424.9 }",
      "comment": "Sprite extruder E-steps — calibrate after install"
    },
    {
      "op": "Custom",
      "mask": "{.*}",
      "searchfor": "DEFAULT_MAX_ACCELERATION",
      "value": "{ 3000, 3000, 100, 1000 }",
      "comment": "Conservative CoreXY start; raise after Input Shaping"
    },
    {
      "op": "CustomVal",
      "searchfor": "INVERT_Z_DIR",
      "value": "false",
      "comment": "Firmware-only fix for Duender conversion: Z+ must move bed down"
    },
    {
      "op": "CustomVal",
      "searchfor": "X_BED_SIZE",
      "value": "230",
      "comment": "CI placeholder — replace after measuring your bed"
    },
    {
      "op": "CustomVal",
      "searchfor": "Y_BED_SIZE",
      "value": "230",
      "comment": "CI placeholder — replace after measuring your bed"
    },
    {
      "op": "CustomVal",
      "searchfor": "X_MAX_POS",
      "value": "248",
      "comment": "CI placeholder — replace after measuring travel"
    },
    {
      "op": "CustomVal",
      "searchfor": "Y_MAX_POS",
      "value": "231",
      "comment": "CI placeholder — replace after measuring travel"
    },
    {
      "op": "CustomVal",
      "searchfor": "Z_MAX_POS",
      "value": "280",
      "comment": "CI placeholder — typical Duender range; measure yours"
    },
    {
      "op": "Custom",
      "mask": "{.*}",
      "searchfor": "NOZZLE_TO_PROBE_OFFSET",
      "value": "{ -41.5, -7, 0 }",
      "comment": "CI placeholder Ender mount — measure your CR Touch mount"
    }
  ],
  "Configuration_adv.h": [
    {
      "op": "CustomVal",
      "searchfor": "CONFIGURATION_ADV_H_VERSION",
      "value": "02010300",
      "comment": "Match New-Year-2025 Marlin"
    }
  ],
  "platformio.ini": [
    {
      "op": "Replace",
      "searchfor": "default_envs = STM32F103RC_creality",
      "value": "default_envs = STM32F103RE_creality",
      "comment": "GD32F303RET6 Neo 4.2.2 (512K) — Mriscoc env STM32F103RE_creality; do not use RC (256K)"
    }
  ]
}
